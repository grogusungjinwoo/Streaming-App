{
  "name": "streaming-app",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first camera recorder for GitHub Pages and desktop MP4 export.",
  "type": "module",
  "homepage": "https://grogusungjinwoo.github.io/Streaming-App/",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:build": "tsc -p electron/tsconfig.json",
    "electron:dev": "npm run electron:build && electron .",
    "electron:pack": "npm run build && npm run electron:build && electron-builder --dir"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "lucide-react": "^0.468.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "electron-builder": "^26.0.12",
    "jsdom": "^27.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  },
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.grogusungjinwoo.streamingapp",
    "productName": "Streaming App",
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/**"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "win": {
      "target": "nsis"
    }
  }
}
